{
  "name": "@neverprepared/mcp-obsidian-second-brain",
  "version": "0.7.0",
  "description": "MCP server for Obsidian-based second brain memory using PARA methodology",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mcp-obsidian-second-brain": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/neverprepared/mcp-obsidian-second-brain.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "obsidian",
    "second-brain",
    "para",
    "memory"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neverprepared/mcp-obsidian-second-brain": "^0.2.0",
    "better-sqlite3": "^12.9.0",
    "gray-matter": "^4.0.3",
    "slugify": "^1.6.6",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
